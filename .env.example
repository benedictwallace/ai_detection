
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Model to use for data collection (cost vs quality tradeoff)
# Fast & cheap:  claude-haiku-4-5-20251001
# Balanced:      claude-sonnet-4-6
COLLECTION_MODEL=claude-haiku-4-5-20251001

# -----------------------------------------------------------------------------
# Data collection settings
# -----------------------------------------------------------------------------

# Max output tokens per generated sample
MAX_TOKENS=512

# Requests per minute — keep below your API tier limit
# Anthropic free tier: ~50 RPM | Tier 1: ~1000 RPM
RATE_LIMIT_RPM=50

# Number of retries on transient API errors
RETRY_LIMIT=3

# Seconds to wait between retries
RETRY_DELAY=5

# -----------------------------------------------------------------------------
# Paths
# -----------------------------------------------------------------------------
OUTPUT_DIR=data
CLAUDE_OUTPUT_FILE=data/claude_samples.jsonl
OPENAI_OUTPUT_FILE=data/openai_samples.jsonl
HUMAN_OUTPUT_FILE=data/human_samples.jsonl
LOG_FILE=data/collection_log.txt

# -----------------------------------------------------------------------------
# Paraphraser training
# -----------------------------------------------------------------------------

# Base model for the paraphraser (T5 or BART)
PARAPHRASER_BASE_MODEL=google/flan-t5-base

# Number of rewrite candidates to generate per input
N_CANDIDATES=8

# Keep only the top-k rewrites by reward score
TOP_K=3

# Minimum reward score to accept a rewrite as a training example
REWARD_THRESHOLD=0.65

# Reward function weights (must sum to 1.0)
REWARD_WEIGHT_DETECTOR=0.5
REWARD_WEIGHT_FLUENCY=0.3
REWARD_WEIGHT_SEMANTIC=0.2

# Paraphraser fine-tuning learning rate
LEARNING_RATE=2e-5

# Training batch size
BATCH_SIZE=8

# Number of training epochs per loop iteration
EPOCHS=3

# -----------------------------------------------------------------------------
# Detector model
# -----------------------------------------------------------------------------

# Pretrained detector to use as the scoring oracle (frozen during paraphraser training)
DETECTOR_MODEL=Hello-SimpleAI/chatgpt-detector-roberta

# Path to save your fine-tuned detector checkpoints
DETECTOR_CHECKPOINT_DIR=checkpoints/detector

# Path to save paraphraser checkpoints
PARAPHRASER_CHECKPOINT_DIR=checkpoints/paraphraser

# Minimum detector evasion rate (%) to consider a training iteration successful
EVASION_TARGET=70
